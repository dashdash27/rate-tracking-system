# Настройки API
# Получить ключ можно здесь: https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=your_api_key_here
BASE_CURRENCY=USD

# Интервал запросов в минутах
FETCH_INTERVAL=10

# Настройки PostgreSQL (для Docker Compose)
POSTGRES_USER=currencyuser
POSTGRES_PASSWORD=currencypassword
POSTGRES_DB=currencydb

# Строка подключения для SQLAlchemy
DATABASE_URL=postgresql://currencyuser:currencypassword@db:5432/currencydb